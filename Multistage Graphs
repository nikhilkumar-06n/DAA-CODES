#include <stdio.h>
int main() {
    int n;
    printf("Enter number of vertices: ");
    scanf("%d", &n);
    int cost[n][n];
    printf("Enter cost adjacency matrix (0 for no edge):\n");
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            scanf("%d", &cost[i][j]);
    int dist[n];
    int path[n];
    for (int i = 0; i < n; i++)
        dist[i] = 0;
    for (int i = n - 2; i >= 0; i--) {
        int min = 0;
        for (int j = i + 1; j < n; j++) {
            if (cost[i][j] != 0) {
                int value = cost[i][j] + dist[j];
                if (min == 0 || value < min) {
                    min = value;
                    path[i] = j;
                }
            }
        }
        dist[i] = min;
    }
    printf("Minimum cost from 0 to %d is: %d\n", n - 1, dist[0]);
    printf("Path: 0 ");
    int i = 0;
    while (i != n - 1) {
        i = path[i];
        printf("-> %d ", i);
    }
    return 0;
}
