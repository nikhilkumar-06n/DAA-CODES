#include <stdio.h>

int main()
{
    int cost[10][10], dist[10], visited[10];
    int i, j, n, source, min, next;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter cost matrix:\n");
    for(i = 0; i < n; i++)
    {
        for(j = 0; j < n; j++)
        {
            scanf("%d", &cost[i][j]);
        }
    }

    printf("Enter source vertex: ");
    scanf("%d", &source);

    for(i = 0; i < n; i++)
    {
        dist[i] = cost[source][i];
        visited[i] = 0;
    }

    visited[source] = 1;

    for(i = 1; i < n; i++)
    {
        min = 999;

        for(j = 0; j < n; j++)
        {
            if(dist[j] < min && visited[j] == 0)
            {
                min = dist[j];
                next = j;
            }
        }

        visited[next] = 1;

        for(j = 0; j < n; j++)
        {
            if(visited[j] == 0)
            {
                if(min + cost[next][j] < dist[j])
                {
                    dist[j] = min + cost[next][j];
                }
            }
        }
    }

    printf("Shortest distances from source:\n");
    for(i = 0; i < n; i++)
    {
        printf("%d -> %d = %d\n", source, i, dist[i]);
    }

    return 0;
}
